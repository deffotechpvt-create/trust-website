{
    "info": {
        "name": "Arul Trust - Backend API",
        "description": "Complete API collection for Arul Trust donation system with auto token management",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "_exporter_id": "12345678"
    },
    "item": [
        {
            "name": "Auth Routes",
            "item": [
                {
                    "name": "Admin Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "",
                                    "if (jsonData.success && jsonData.token) {",
                                    "    pm.collectionVariables.set(\"admin_token\", jsonData.token);",
                                    "    pm.collectionVariables.set(\"admin_id\", jsonData.admin.id);",
                                    "    pm.collectionVariables.set(\"admin_email\", jsonData.admin.email);",
                                    "    pm.collectionVariables.set(\"admin_name\", jsonData.admin.name);",
                                    "    ",
                                    "    pm.test(\"Login successful\", function () {",
                                    "        pm.expect(jsonData.success).to.be.true;",
                                    "        pm.expect(jsonData.token).to.be.a('string');",
                                    "    });",
                                    "    ",
                                    "    console.log(\"✅ Token saved automatically: \" + jsonData.token.substring(0, 20) + \"...\");",
                                    "} else {",
                                    "    pm.test(\"Login failed\", function () {",
                                    "        pm.expect.fail(\"Login was not successful\");",
                                    "    });",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@gmail.com\",\n  \"password\": \"Test@123\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/login",
                            "host": ["{{base_url}}"],
                            "path": ["api", "auth", "login"]
                        },
                        "description": "Login with admin credentials - Token will be saved automatically"
                    },
                    "response": []
                },
                {
                    "name": "Change Password",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 200\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "var jsonData = pm.response.json();",
                                    "pm.test(\"Password changed successfully\", function () {",
                                    "    pm.expect(jsonData.success).to.be.true;",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{admin_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"currentPassword\": \"Test@123\",\n  \"newPassword\": \"NewPassword@123\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/change-password",
                            "host": ["{{base_url}}"],
                            "path": ["api", "auth", "change-password"]
                        },
                        "description": "Change admin password (uses auto-saved token)"
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Razorpay - Registered Donor",
            "item": [
                {
                    "name": "Create Order (With Donor Details)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "",
                                    "if (jsonData.success && jsonData.orderId) {",
                                    "    pm.collectionVariables.set(\"last_order_id\", jsonData.orderId);",
                                    "    pm.collectionVariables.set(\"last_order_amount\", jsonData.amount);",
                                    "    ",
                                    "    pm.test(\"Order created successfully\", function () {",
                                    "        pm.expect(jsonData.success).to.be.true;",
                                    "        pm.expect(jsonData.orderId).to.be.a('string');",
                                    "    });",
                                    "    ",
                                    "    console.log(\"✅ Order created: \" + jsonData.orderId);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"amount\": 100000,\n  \"currency\": \"INR\",\n  \"donationType\": \"one-time\",\n  \"purpose\": \"education\",\n  \"paymentMethod\": \"upi\",\n  \"donorDetails\": {\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"phone\": \"9876543210\",\n    \"address\": \"123 Main Street\",\n    \"city\": \"Mumbai\",\n    \"state\": \"Maharashtra\",\n    \"pincode\": \"400001\",\n    \"pan\": \"ABCDE1234F\",\n    \"taxCertificateRequired\": true\n  }\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/razorpay/order",
                            "host": ["{{base_url}}"],
                            "path": ["api", "razorpay", "order"]
                        },
                        "description": "Create order - Order ID will be saved automatically"
                    },
                    "response": []
                },
                {
                    "name": "Verify Payment (With Donor)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "",
                                    "pm.test(\"Payment verified successfully\", function () {",
                                    "    pm.expect(jsonData.success).to.be.true;",
                                    "});",
                                    "",
                                    "if (jsonData.success && jsonData.donation) {",
                                    "    console.log(\"✅ Payment verified for order: \" + jsonData.donation.orderId);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"razorpay_order_id\": \"{{last_order_id}}\",\n  \"razorpay_payment_id\": \"pay_yyyyyyyyyyyyy\",\n  \"razorpay_signature\": \"generated_signature_here\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/razorpay/verify",
                            "host": ["{{base_url}}"],
                            "path": ["api", "razorpay", "verify"]
                        },
                        "description": "Verify payment (uses auto-saved order_id)"
                    },
                    "response": []
                }
            ]
        },
